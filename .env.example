# Optional market-data / explorer keys
COINGECKO_API_KEY=
ETHERSCAN_V2_API_KEY=XFYBWMNYA62ZRW6PK252CVYIYM2H5GZ6YP
ETHERSCAN_API_KEY=XFYBWMNYA62ZRW6PK252CVYIYM2H5GZ6YP
# Legacy per-explorer keys are accepted as fallback env vars, but Etherscan V2 uses one Etherscan key plus chainid.
BSCSCAN_API_KEY=XFYBWMNYA62ZRW6PK252CVYIYM2H5GZ6YP
ARBISCAN_API_KEY=XFYBWMNYA62ZRW6PK252CVYIYM2H5GZ6YP
ARBSCAN_API_KEY=XFYBWMNYA62ZRW6PK252CVYIYM2H5GZ6YP
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
COINMARKETCAP_API_KEY=

# Dashboard / scanner sizing
MAX_SYMBOLS_TO_SCAN=75
FAST_MAX_SYMBOLS=30
MARKET_STRUCTURE_SYMBOLS_TO_SCAN=6
MARKET_STRUCTURE_MIN_QUOTE_VOLUME=2500000
NO_LARGE_PUMP_THRESHOLD_PCT=35
# Deprecated: DISCORD_REQUIRE_BITGET_OR_GATE is ignored; Binance+Bitget is pinned on for thesis gates.
# Deprecated compatibility knob: thesis gates ignore symbol text as Binance proof.
# Fresh scans must provide binance_perp_universe, Binance share, or top-venue text.
DISCORD_ASSUME_SYMBOLS_ARE_BINANCE_PERPS=0
DISCORD_VENUE_GATE_MIN_SHARE_PCT=0

# Discord webhook watcher
DISCORD_WEBHOOK_URL=
DISCORD_CONVEX_ALERTS_ENABLED=1
DISCORD_WATCHER_SCAN_MODE=Deep
DISCORD_WATCHER_ALERT_SOURCE=terminal_timing
DISCORD_WATCHER_SCAN_INTERVAL_SECONDS=180
DISCORD_WATCHER_TOP_N=25
DISCORD_WATCHER_REALERT_HOURS=12
DISCORD_WATCHER_MIN_TERMINAL_SCORE=60
DISCORD_WATCHER_MIN_TIMING_SCORE=55

# 24/7 short-account 1h rate-of-change Discord monitor
# Uses SHORT_ROC_DISCORD_WEBHOOK_URL when set, otherwise falls back to DISCORD_WEBHOOK_URL.
SHORT_ROC_DISCORD_WEBHOOK_URL=
SHORT_ROC_INTERVAL_SECONDS=300
SHORT_ROC_PERIOD=1h
SHORT_ROC_HISTORY_LIMIT=2
SHORT_ROC_MIN_ABS_PP=1.5
SHORT_ROC_MIN_ABS_PCT=3.0
SHORT_ROC_MIN_QUOTE_VOLUME=0
SHORT_ROC_TOP_N=25
SHORT_ROC_REALERT_HOURS=6
SHORT_ROC_MAX_SYMBOLS=0
SHORT_ROC_SYMBOLS=
SHORT_ROC_OUTPUT_DIR=short_account_roc_output
SHORT_ROC_SUPPRESS_INITIAL_ALERTS=0

# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_ID=
DISCORD_CLEAR_GLOBAL_COMMANDS_ON_GUILD_SYNC=0
DISCORD_COMMAND_LIVE_SCAN_ENABLED=1
DISCORD_CONVEX_COMMAND_TOP_N=10
DISCORD_ALPHA_TOP_N=15
DISCORD_ALPHA_BRIEF_MIN_SCORE=35
DISCORD_CORR_SCAN_MODE=Deep
DISCORD_BREAKOUT_SCAN_MODE=Deep
DISCORD_EARLY_FLOW_MIN_TOKENS=20000
DISCORD_RAVELAB_WHALE_FLOW_MIN_TOKENS=100000
DISCORD_RAVELAB_MASSIVE_WHALE_FLOW_MIN_TOKENS=10000000
DISCORD_DEFAULT_USER_TIER=pro
DISCORD_FREE_SAMPLE_TOP_N=3
DISCORD_PAID_ROLE_IDS=
DISCORD_PRO_ROLE_IDS=

# Holder composition and wallet-to-CEX flow
DISCORD_HOLDER_COMPOSITION_ENABLED=1
DISCORD_HOLDER_CONTRACTS_FILE=data/discord_holder_contracts.csv
CEX_DEPOSIT_FLOW_ENABLED=1
CEX_DEPOSIT_FLOW_MAX_SYMBOLS=0
CEX_DEPOSIT_FLOW_LOOKBACK_HOURS=24
CEX_DEPOSIT_FLOW_MIN_TRANSFER_TOKENS=500000
CEX_DEPOSIT_FLOW_MIN_TOP10_PCT=90
# Optional API fallback labels for explorer 403s. CSV columns: chain,address,label
CEX_ADDRESS_BOOK_FILE=data/cex_address_book.csv
# Inline form also works: base:0xabc...=Bitget Deposit;ethereum:0xdef...=Binance
CEX_ADDRESS_LABELS=

# Proof archive
DISCORD_PROOF_ARCHIVE_ROOT=data/archive
DISCORD_PROOF_REFRESH_ENABLED=1
DISCORD_SCOREBOARD_REFRESH_OUTCOMES=1
DISCORD_WEEKLY_REPORT_WRITE_ENABLED=1
